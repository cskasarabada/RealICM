{
  "name": "realicm",
  "version": "1.0.0",
  "description": "RealICM - Oracle ICM Analytics Engine",
  "main": "main.js",
  "author": {
    "name": "Chandra Kasarabada"
  },
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.cskasarabada.realicm",
    "productName": "RealICM",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "cskasarabada",
      "repo": "RealICM"
    }
  }
}
